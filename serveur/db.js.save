  verbose: process// ════════════════════════════════════════════════════════════
// server/db.js — Couche d'accès aux données (SQLite)
// ════════════════════════════════════════════════════════════
 
const Database = require('better-sqlite3');
const path = require('path'); // module Node.js natif pour les chemins
const fs   = require('fs');   // module Node.js natif pour les fichiers
 
// ── CONNEXION À LA BASE ──────────────────────────────────
// path.join construit un chemin compatible Windows/Mac/Linux
// __dirname : répertoire du fichier actuel (server/)
// '../db/epargne.sqlite' : remonte d'un niveau puis va dans db/
const dbPath = process.env.DB_PATH ||
  path.join(__dirname, '../db/epargne.sqlite');
 
// new Database() : ouvre ou crée le fichier SQLite
// verbose: console.log en dev pour voir les requêtes exécutées
const db = new Database(dbPath, {
  verbose: process.env.NODE_ENV === 'development' ? console.log : null
});
 
// ── OPTIMISATIONS SQLITE ─────────────────────────────────
// WAL (Write-Ahead Logging) : permet lectures et écritures simultanées
// Améliore drastiquement les performances en écriture
db.pragma('journal_mode = WAL');
 
// foreign_keys : désactivé par défaut dans SQLite pour compatibilité
// On l'active explicitement pour respecter nos contraintes FOREIGN KEY
db.pragma('foreign_keys = ON');
 
const DB = {
 
  // ── INITIALISATION ────────────────────────────────────
  // Lit le schéma SQL et crée les tables si elles n'existent pas
  // Appelé une fois au démarrage du serveur (index.js → db.init())
  init() {
    const schemaPath = path.join(__dirname, '../db/schema.sql');
    const schema = fs.readFileSync(schemaPath, 'utf8');
    // db.exec() : exécute plusieurs instructions SQL d'un coup
    db.exec(schema);
    console.log('✅ Base de données initialisée');
  },
 
  // ── TRANSACTIONS — READ ───────────────────────────────
  // Retourne toutes les transactions d'un utilisateur
  // options : filtres optionnels (month, category, type)
  getTransactions(userId, options = {}) {
    // Construction dynamique de la requête SQL selon les filtres
    let query = 'SELECT * FROM transactions WHERE user_id = ?';
    const params = [userId]; // tableau des paramètres (protège contre injection)
 
    // Ajouter les conditions de filtre si elles sont fournies
    if (options.month) {
      // strftime : fonction SQLite pour formater une date
      // '%Y-%m' extrait l'année et le mois d'une date
      query += " AND strftime('%Y-%m', date) = ?";
      params.push(options.month);
    }
    if (options.category) {
      query += ' AND category = ?';
      params.push(options.category);
    }
    if (options.type) {
      query += ' AND type = ?';
      params.push(options.type);
    }
 
    query += ' ORDER BY date DESC, created_at DESC';
 
    // db.prepare() : compile la requête une fois
    // .all() : exécute et retourne TOUS les résultats (tableau)
    // .get() retournerait une seule ligne, .run() pour INSERT/UPDATE/DELETE
    return db.prepare(query).all(...params);
  },
 
  // ── TRANSACTIONS — CREATE ─────────────────────────────
  addTransaction(data) {
    // Requête préparée nommée (@nom) : plus lisible que les ?
    // SQLite injecte les valeurs depuis l'objet passé à .run()
    const stmt = db.prepare(`
      INSERT INTO transactions
        (user_id, description, amount, type, category, date)
      VALUES
        (@userId, @description, @amount, @type, @category, @date)
    `);
 
    // .run() retourne { lastInsertRowid, changes }
    const result = stmt.run({
      userId:      data.userId || 'demo',
      description: data.description,
      amount:      data.amount,
      type:        data.type,
      category:    data.category,
      date:        data.date,
    });
 
    // Retourner l'objet complet avec son ID (pour la réponse HTTP)
    return { id: result.lastInsertRowid, ...data };
  },
 
  // ── TRANSACTIONS — UPDATE ─────────────────────────────
  updateTransaction(id, changes) {
    const stmt = db.prepare(`
      UPDATE transactions
      SET description = @description,
          amount      = @amount,
          type        = @type,
          category    = @category,
          date        = @date
      WHERE id = @id
    `);
    stmt.run({ ...changes, id });
    return { id, ...changes };
  },
 
  // ── TRANSACTIONS — DELETE ─────────────────────────────
  deleteTransaction(id) {
    db.prepare('DELETE FROM transactions WHERE id = ?').run(id);
  },
 
  // ── OBJECTIFS — CRUD complet ──────────────────────────
  getGoals(userId) {
    return db.prepare('SELECT * FROM goals WHERE user_id = ? ORDER BY created_at DESC')
      .all(userId);
  },
 
  addGoal(data) {
    const stmt = db.prepare(`
      INSERT INTO goals (user_id, name, emoji, target_amount, current_amount, deadline)
      VALUES (@userId, @name, @emoji, @targetAmount, @currentAmount, @deadline)`,
    );
    const result = stmt.run({
      userId: data.userId || 'demo',
      name: data.name, emoji: data.emoji || '🎯',
      targetAmount: data.targetAmount,
      currentAmount: data.currentAmount || 0,
      deadline: data.deadline || null,
    });
    return { id: result.lastInsertRowid, ...data };
  },
 
  updateGoal(id, changes) {
    db.prepare(`UPDATE goals SET name=@name, emoji=@emoji,
      target_amount=@targetAmount, current_amount=@currentAmount,
      deadline=@deadline WHERE id=@id`
    ).run({ ...changes, id });
    return { id, ...changes };
  },
 
  deleteGoal(id) {
    db.prepare('DELETE FROM goals WHERE id = ?').run(id);
  }
};
 
module.exports = DB;
