# ════════════════════════════════════════════════════════════
# server/.env — Variables d'environnement sensibles
# JAMAIS committer ce fichier ! Ajouté dans .gitignore
# Dupliquer en .env.example avec des valeurs vides pour documenter
# ════════════════════════════════════════════════════════════
 
# Clé API Anthropic — obtenir sur console.anthropic.com
# Format : sk-ant-api03-...

 
# Chemin vers le fichier SQLite (relatif à server/)
DB_PATH=./db/epargne.sqlite
 
# Port du serveur Express (Railway peut l'override automatiquement)
PORT=3000
 
# Clé secrète pour signer les JWT — générer avec : openssl rand -hex 32
JWT_SECRET=remplacer_par_une_chaine_aleatoire_de_32_caracteres_minimum
 
# Environnement : development | production
NODE_ENV=development
 
# URL autorisée par CORS (adresse du frontend)
CORS_ORIGIN=http://localhost:5500
